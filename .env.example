# GA4 measurement ID used by analytics injection scripts and runtime GA loaders.
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# AJAX endpoint that receives volunteer sign-up form submissions.
SIGNUP_ENDPOINT=https://formsubmit.co/ajax/volunteer@arafatforcongress.org

# Shared admin secret for protecting silo/admin operations.
SILO_ADMIN_SECRET=please-change-this-secret

# Optional override URL for the conversations feed JSON consumed by js/conversations-feed.js.
CONVERSATIONS_FEED_URL=https://example.com/path/to/conversations.json

# Supabase project URL used by dashboard/server components.
SUPABASE_URL=
# Supabase anon/public key used by client-side Supabase access.
SUPABASE_ANON_KEY=
# Supabase service role key used by trusted server-side jobs.
SUPABASE_SERVICE_ROLE_KEY=
# Mapbox token used by mapping components.
MAPBOX_TOKEN=
# Optional Google Maps API key for Google-based geocoding/maps features.
GOOGLE_MAPS_API_KEY=
# Optional Twilio account SID for SMS integrations.
TWILIO_ACCOUNT_SID=
# Optional Twilio auth token for SMS integrations.
TWILIO_AUTH_TOKEN=
# Optional Twilio messaging service SID for outbound texting.
TWILIO_MESSAGING_SERVICE_SID=

# --- Vanguard Field Ops V3 ---
PORT=4177
DB_PATH=./data/vanguard-v3.sqlite
WORKER_INTERVAL_MS=5000
IMPORT_CHUNK_SIZE=250
GEOCODE_BATCH_SIZE=50
VITE_V3_API_BASE_URL=http://localhost:4177/api/v3

# Provider defaults (Google is optional and not required)
CENSUS_RPS=5
CENSUS_TIMEOUT_MS=12000
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=vanguard-field-ops-v3/1.0
NOMINATIM_RPS=1

# Optional external APIs
CENSUS_API_KEY=
OPENSTATES_API_KEY=
FEC_API_KEY=
OPENROUTESERVICE_API_KEY=

# Optional AI adapters only
AI_PROVIDER=none
GEMINI_API_KEY=
